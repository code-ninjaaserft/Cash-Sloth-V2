<Window x:Class="CashSloth.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CashSloth POS" Height="720" Width="1240"
        Loaded="OnWindowLoaded"
        Closing="OnWindowClosing">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="760" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            BorderBrush="{DynamicResource AppControlBorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="8"
            Margin="0,0,0,10"
            Background="{DynamicResource AppSurfaceBrush}">
      <TabControl x:Name="ToolbarTabControl" BorderThickness="0" Background="Transparent">
        <TabItem Header="Settings">
          <WrapPanel VerticalAlignment="Center" Margin="0,4,0,0">
            <TextBlock Text="Language" FontSize="14" FontWeight="SemiBold" Margin="0,0,8,0" VerticalAlignment="Center" />
            <ComboBox x:Name="LanguageComboBox"
                      Width="190"
                      Height="34"
                      Margin="0,0,14,0"
                      VerticalContentAlignment="Center"
                      DisplayMemberPath="Label"
                      SelectedValuePath="Value"
                      SelectionChanged="OnLanguageSelectionChanged" />

            <TextBlock Text="Currency" FontSize="14" FontWeight="SemiBold" Margin="0,0,8,0" VerticalAlignment="Center" />
            <ComboBox x:Name="CurrencyComboBox"
                      Width="130"
                      Height="34"
                      Margin="0,0,14,0"
                      VerticalContentAlignment="Center"
                      DisplayMemberPath="Label"
                      SelectedValuePath="Value"
                      SelectionChanged="OnCurrencySelectionChanged" />

            <TextBlock Text="UI Color" FontSize="14" FontWeight="SemiBold" Margin="0,0,8,0" VerticalAlignment="Center" />
            <ComboBox x:Name="ThemeComboBox"
                      Width="140"
                      Height="34"
                      VerticalContentAlignment="Center"
                      DisplayMemberPath="Label"
                      SelectedValuePath="Value"
                      SelectionChanged="OnThemeSelectionChanged" />
          </WrapPanel>
        </TabItem>

        <TabItem Header="Presets">
          <Grid Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource AppControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8">
              <StackPanel>
                <TextBlock Text="Local presets" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ComboBox x:Name="LocalPresetComboBox"
                          Height="34"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Value" />
                <WrapPanel Margin="0,8,0,0">
                  <Button Content="Switch preset" Width="120" Height="34" Click="OnSwitchPresetClick" />
                  <Button Content="Refresh" Width="90" Height="34" Margin="6,0,0,0" Click="OnRefreshPresetListClick" />
                  <Button Content="Delete preset" Width="120" Height="34" Margin="6,0,0,0" Click="OnDeletePresetClick" />
                </WrapPanel>

                <TextBlock Text="Save current as" FontWeight="SemiBold" Margin="0,10,0,4" />
                <TextBox x:Name="NewPresetNameTextBox"
                         Height="34"
                         VerticalContentAlignment="Center"
                         ToolTip="Preset name (e.g. Summer Menu)" />
                <WrapPanel Margin="0,8,0,0">
                  <Button Content="Save current preset" Width="170" Height="34" Click="OnSaveCurrentPresetClick" />
                  <CheckBox x:Name="SetSavedPresetActiveCheckBox"
                            Content="Set active"
                            Margin="12,8,0,0"
                            VerticalAlignment="Center"
                            IsChecked="True" />
                </WrapPanel>
              </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource AppControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8">
              <StackPanel>
                <TextBlock Text="Online preset import" FontWeight="SemiBold" Margin="0,0,0,6" />

                <TextBlock Text="Preset URL" Margin="0,2,0,2" />
                <TextBox x:Name="OnlinePresetUrlTextBox"
                         Height="34"
                         VerticalContentAlignment="Center"
                         ToolTip="Preset JSON URL (https://...)" />

                <TextBlock Text="Optional preset name" Margin="0,8,0,2" />
                <TextBox x:Name="OnlinePresetNameTextBox"
                         Height="34"
                         VerticalContentAlignment="Center"
                         ToolTip="Override preset name" />

                <WrapPanel Margin="0,8,0,0">
                  <Button Content="Import online preset" Width="180" Height="34" Click="OnImportOnlinePresetClick" />
                  <CheckBox x:Name="SetImportedPresetActiveCheckBox"
                            Content="Set active"
                            Margin="12,8,0,0"
                            VerticalAlignment="Center"
                            IsChecked="False" />
                </WrapPanel>

                <TextBlock Text="Supports preset JSON and store JSON with presets."
                           Margin="0,8,0,0"
                           FontSize="12"
                           Opacity="0.8" />
              </StackPanel>
            </Border>
          </Grid>
        </TabItem>
      </TabControl>
    </Border>

    <GroupBox Grid.Row="1" Grid.Column="0" Header="Products" Margin="0,0,12,0">
      <Grid Margin="8">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
          <CheckBox x:Name="EditModeCheckBox"
                    Content="Edit mode"
                    Margin="0,0,10,0"
                    FontSize="16"
                    VerticalAlignment="Center"
                    Checked="OnEditModeChanged"
                    Unchecked="OnEditModeChanged" />
          <Button x:Name="OpenCatalogEditorButton"
                  Content="Catalog Editor"
                  Width="140"
                  Height="42"
                  FontSize="15"
                  Visibility="Collapsed"
                  Click="OnOpenCatalogEditorClick" />
          <Button x:Name="OpenAddItemButton"
                  Content="Add Item"
                  Width="120"
                  Height="42"
                  FontSize="15"
                  Margin="8,0,0,0"
                  Visibility="Collapsed"
                  Click="OnOpenAddItemOverlayClick" />
          <Button x:Name="OpenCategoryManagerButton"
                  Content="Categories"
                  Width="120"
                  Height="42"
                  FontSize="15"
                  Margin="8,0,0,0"
                  Visibility="Collapsed"
                  Click="OnOpenCategoryManagerClick" />
        </StackPanel>

        <Grid Grid.Row="1">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="132" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0" BorderBrush="{DynamicResource AppControlBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <TextBlock Text="Categories" FontWeight="SemiBold" />
              <ScrollViewer Grid.Row="1"
                            Margin="0,6,0,0"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled"
                            PanningMode="VerticalOnly">
                <StackPanel x:Name="CategoryButtonsPanel" />
              </ScrollViewer>
            </Grid>
          </Border>

          <Border Grid.Column="2" BorderBrush="{DynamicResource AppControlBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <TextBlock Text="Items" FontWeight="SemiBold" />
              <ScrollViewer Grid.Row="1"
                            Margin="0,6,0,0"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled"
                            PanningMode="VerticalOnly">
                <WrapPanel x:Name="ProductsPanel" Orientation="Horizontal" />
              </ScrollViewer>
            </Grid>
          </Border>
        </Grid>
      </Grid>
    </GroupBox>

    <GroupBox Grid.Row="1" Grid.Column="1" Header="Cart">
      <DataGrid x:Name="CartLinesGrid"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                IsReadOnly="True"
                SelectionMode="Single"
                SelectionUnit="FullRow"
                ScrollViewer.PanningMode="Both">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Item" Binding="{Binding Name}" Width="*" />
          <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="70" />
          <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotalDisplay}" Width="140" />
        </DataGrid.Columns>
      </DataGrid>
    </GroupBox>

    <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,12,0,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <StackPanel Grid.Row="0" Orientation="Horizontal">
        <Button Content="Remove Selected" Width="160" Height="38" Click="OnRemoveSelectedClick" />
        <Button Content="Clear" Width="100" Height="38" Margin="8,0,0,0" Click="OnClearClick" />

        <Separator Margin="16,0,16,0" Width="1" />

        <Button Content="Open Customer Display" Width="200" Height="38" Click="OnOpenCustomerDisplayClick" />
        <Button Content="Close Customer Display" Width="200" Height="38" Margin="6,0,0,0" Click="OnCloseCustomerDisplayClick" />
      </StackPanel>

      <WrapPanel x:Name="GivenButtonsPanel" Grid.Row="1" Margin="0,10,0,0" VerticalAlignment="Center">
        <TextBlock Text="Given:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14" FontWeight="SemiBold" />

        <Button Content="0.05" Tag="5" Width="58" Height="36" Click="OnAddGivenClick" />
        <Button Content="0.10" Tag="10" Width="58" Height="36" Margin="4,0,0,0" Click="OnAddGivenClick" />
        <Button Content="0.20" Tag="20" Width="58" Height="36" Margin="4,0,0,0" Click="OnAddGivenClick" />
        <Button Content="0.50" Tag="50" Width="58" Height="36" Margin="4,0,0,0" Click="OnAddGivenClick" />
        <Button Content="1" Tag="100" Width="58" Height="36" Margin="4,0,0,0" Click="OnAddGivenClick" />
        <Button Content="2" Tag="200" Width="58" Height="36" Margin="4,0,0,0" Click="OnAddGivenClick" />
        <Button Content="5" Tag="500" Width="58" Height="36" Margin="4,0,0,0" Click="OnAddGivenClick" />
        <Button Content="10" Tag="1000" Width="58" Height="36" Margin="4,0,0,0" Click="OnAddGivenClick" />
        <Button Content="20" Tag="2000" Width="58" Height="36" Margin="4,0,0,0" Click="OnAddGivenClick" />
        <Button Content="50" Tag="5000" Width="58" Height="36" Margin="4,0,0,0" Click="OnAddGivenClick" />
        <Button Content="100" Tag="10000" Width="58" Height="36" Margin="4,0,0,0" Click="OnAddGivenClick" />
        <Button Content="200" Tag="20000" Width="58" Height="36" Margin="4,0,0,0" Click="OnAddGivenClick" />
        <Button Content="1000" Tag="100000" Width="62" Height="36" Margin="4,0,0,0" Click="OnAddGivenClick" />

        <Button Content="Given reset" Width="110" Height="36" Margin="12,0,0,0" Click="OnResetGivenClick" />

        <TextBox x:Name="CustomGivenTextBox"
                 Width="120"
                 Height="36"
                 FontSize="16"
                 Margin="12,0,0,0"
                 VerticalContentAlignment="Center"
                 ToolTip="Custom amount (e.g. 12.50)" />
        <Button Content="Add Custom"
                Width="110"
                Height="36"
                Margin="6,0,0,0"
                Click="OnAddCustomGivenClick" />
      </WrapPanel>
    </Grid>

    <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,12,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0">
        <TextBlock Text="Total" FontWeight="SemiBold" FontSize="14" />
        <TextBlock x:Name="TotalValueText" FontSize="34" FontWeight="SemiBold" Text="CHF 0.00" />
      </StackPanel>
      <StackPanel Grid.Column="1">
        <TextBlock Text="Given" FontWeight="SemiBold" FontSize="14" />
        <TextBlock x:Name="GivenValueText" FontSize="34" FontWeight="SemiBold" Text="CHF 0.00" />
      </StackPanel>
      <StackPanel Grid.Column="2">
        <TextBlock Text="Change" FontWeight="SemiBold" FontSize="14" />
        <TextBlock x:Name="ChangeValueText" FontSize="34" FontWeight="SemiBold" Text="CHF 0.00" />
        <TextBlock x:Name="BalanceHintText" FontSize="16" FontWeight="SemiBold" Text="Exact amount" />
      </StackPanel>
    </Grid>

    <TextBlock Grid.Row="4"
               Grid.Column="0"
               Grid.ColumnSpan="2"
               x:Name="StatusText"
               Margin="0,10,0,0"
               FontSize="14" />

    <Border x:Name="CatalogEditorOverlay"
            Grid.Row="0"
            Grid.Column="0"
            Grid.RowSpan="5"
            Grid.ColumnSpan="2"
            Panel.ZIndex="10"
            Background="#77000000"
            Visibility="Collapsed">
      <Border Width="640"
              MaxHeight="610"
              Padding="14"
              Background="{DynamicResource AppSurfaceBrush}"
              BorderBrush="{DynamicResource AppControlBorderBrush}"
              BorderThickness="1"
              CornerRadius="8"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
        <ScrollViewer VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
              <TextBlock Text="Catalog Editor" FontSize="22" FontWeight="SemiBold" DockPanel.Dock="Left" />
              <Button Content="X"
                      Width="42"
                      Height="42"
                      FontSize="16"
                      HorizontalAlignment="Right"
                      DockPanel.Dock="Right"
                      Click="OnCloseCatalogEditorClick" />
            </DockPanel>

            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="Existing items" FontWeight="SemiBold" Margin="0,0,0,4" />
            <ListBox x:Name="EditorItemsListBox"
                     Grid.Row="2"
                     Grid.Column="0"
                     Grid.ColumnSpan="2"
                     Height="180"
                     FontSize="16"
                     ScrollViewer.PanningMode="VerticalOnly"
                     SelectionChanged="OnEditorItemSelectionChanged" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="ID:" VerticalAlignment="Center" Margin="0,8,0,0" />
            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="EditIdText" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,8,0,0" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,8,0,0" />
            <TextBox Grid.Row="4" Grid.Column="1" x:Name="EditNameTextBox" Height="36" FontSize="16" Margin="0,8,0,0" />

            <Grid Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,0">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Row="0" Grid.Column="0" Text="Price:" VerticalAlignment="Center" />
              <TextBox Grid.Row="0" Grid.Column="1" x:Name="EditPriceTextBox" Height="36" FontSize="16" />

              <TextBlock Grid.Row="1" Grid.Column="0" Text="Category:" VerticalAlignment="Center" Margin="0,8,0,0" />
              <ComboBox Grid.Row="1"
                        Grid.Column="1"
                        x:Name="EditCategoryCombo"
                        Height="36"
                        FontSize="16"
                        Margin="0,8,0,0"
                        IsEditable="True" />

              <WrapPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,14,0,0">
                <Button Content="Save" Width="110" Height="40" FontSize="15" Click="OnSaveProductClick" />
                <Button Content="Delete Item" Width="130" Height="40" FontSize="15" Margin="8,0,0,0" Click="OnDeleteProductClick" />
                <Button Content="Close" Width="110" Height="40" FontSize="15" Margin="8,0,0,0" Click="OnCloseCatalogEditorClick" />
              </WrapPanel>
            </Grid>
          </Grid>
        </ScrollViewer>
      </Border>
    </Border>

    <Border x:Name="AddItemOverlay"
            Grid.Row="0"
            Grid.Column="0"
            Grid.RowSpan="5"
            Grid.ColumnSpan="2"
            Panel.ZIndex="30"
            Background="#77000000"
            Visibility="Collapsed">
      <Border Width="520"
              Padding="14"
              Background="{DynamicResource AppSurfaceBrush}"
              BorderBrush="{DynamicResource AppControlBorderBrush}"
              BorderThickness="1"
              CornerRadius="8"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <DockPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
            <TextBlock Text="Add Item" FontSize="22" FontWeight="SemiBold" DockPanel.Dock="Left" />
            <Button Content="X"
                    Width="42"
                    Height="42"
                    FontSize="16"
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Click="OnCloseAddItemOverlayClick" />
          </DockPanel>

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,8,0,0" />
          <TextBox Grid.Row="1" Grid.Column="1" x:Name="AddItemNameTextBox" Height="36" FontSize="16" Margin="0,8,0,0" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Price:" VerticalAlignment="Center" Margin="0,8,0,0" />
          <TextBox Grid.Row="2" Grid.Column="1" x:Name="AddItemPriceTextBox" Height="36" FontSize="16" Margin="0,8,0,0" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Category:" VerticalAlignment="Center" Margin="0,8,0,0" />
          <ComboBox Grid.Row="3"
                    Grid.Column="1"
                    x:Name="AddItemCategoryCombo"
                    Height="36"
                    FontSize="16"
                    Margin="0,8,0,0"
                    IsEditable="True" />

          <WrapPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,14,0,0">
            <Button Content="Create" Width="120" Height="40" FontSize="15" Click="OnCreateNewItemClick" />
            <Button Content="Cancel" Width="120" Height="40" FontSize="15" Margin="8,0,0,0" Click="OnCloseAddItemOverlayClick" />
          </WrapPanel>
        </Grid>
      </Border>
    </Border>

    <Border x:Name="CategoryManagerOverlay"
            Grid.Row="0"
            Grid.Column="0"
            Grid.RowSpan="5"
            Grid.ColumnSpan="2"
            Panel.ZIndex="20"
            Background="#77000000"
            Visibility="Collapsed">
      <Border Width="620"
              MaxHeight="620"
              Padding="14"
              Background="{DynamicResource AppSurfaceBrush}"
              BorderBrush="{DynamicResource AppControlBorderBrush}"
              BorderThickness="1"
              CornerRadius="8"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Edit Mode On - Categories" FontSize="22" FontWeight="SemiBold" DockPanel.Dock="Left" />
            <Button Content="X"
                    Width="42"
                    Height="42"
                    FontSize="16"
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Click="OnCloseCategoryManagerClick" />
          </DockPanel>

          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly">
            <StackPanel x:Name="CategoryManagerRowsPanel" />
          </ScrollViewer>

          <WrapPanel Grid.Row="2" Margin="0,12,0,0">
            <Button Content="Add Category..." Width="150" Height="40" FontSize="15" Click="OnOpenAddCategoryOverlayClick" />
            <Button Content="Close" Width="120" Height="40" FontSize="15" Margin="8,0,0,0" Click="OnCloseCategoryManagerClick" />
          </WrapPanel>
        </Grid>
      </Border>
    </Border>

    <Border x:Name="AddCategoryOverlay"
            Grid.Row="0"
            Grid.Column="0"
            Grid.RowSpan="5"
            Grid.ColumnSpan="2"
            Panel.ZIndex="40"
            Background="#77000000"
            Visibility="Collapsed">
      <Border Width="460"
              Padding="14"
              Background="{DynamicResource AppSurfaceBrush}"
              BorderBrush="{DynamicResource AppControlBorderBrush}"
              BorderThickness="1"
              CornerRadius="8"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Add Category" FontSize="22" FontWeight="SemiBold" DockPanel.Dock="Left" />
            <Button Content="X"
                    Width="42"
                    Height="42"
                    FontSize="16"
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Click="OnCloseAddCategoryOverlayClick" />
          </DockPanel>

          <TextBox Grid.Row="1"
                   x:Name="AddCategoryNameTextBox"
                   Height="38"
                   FontSize="16"
                   VerticalContentAlignment="Center"
                   ToolTip="Category name" />

          <WrapPanel Grid.Row="2" Margin="0,12,0,0">
            <Button Content="Create" Width="120" Height="40" FontSize="15" Click="OnCreateCategoryClick" />
            <Button Content="Cancel" Width="120" Height="40" FontSize="15" Margin="8,0,0,0" Click="OnCloseAddCategoryOverlayClick" />
          </WrapPanel>
        </Grid>
      </Border>
    </Border>
  </Grid>
</Window>
