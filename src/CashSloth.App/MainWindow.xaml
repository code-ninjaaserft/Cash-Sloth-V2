<Window x:Class="CashSloth.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CashSloth POS" Height="620" Width="980"
        Loaded="OnWindowLoaded"
        Closing="OnWindowClosing">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="260" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <GroupBox Grid.Row="0" Grid.Column="0" Header="Products" Margin="0,0,12,0">
      <Grid Margin="8">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
          <TextBlock Text="Category:" VerticalAlignment="Center" Margin="0,0,6,0" />
          <ComboBox x:Name="CategoryFilterCombo" Width="130" SelectionChanged="OnCategoryFilterChanged" />
          <CheckBox x:Name="EditModeCheckBox" Content="Edit mode" Margin="10,0,0,0" VerticalAlignment="Center" Checked="OnEditModeChanged" Unchecked="OnEditModeChanged" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
          <WrapPanel x:Name="ProductsPanel" />
        </ScrollViewer>

        <Border Grid.Row="2" x:Name="EditPanel" Margin="0,8,0,0" Padding="8" BorderBrush="#FFB8B8B8" BorderThickness="1" CornerRadius="4" Visibility="Collapsed">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="90" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="ID:" VerticalAlignment="Center" />
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="EditIdText" FontWeight="SemiBold" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,6,0,0" />
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="EditNameTextBox" Margin="0,6,0,0" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Price CHF:" VerticalAlignment="Center" Margin="0,6,0,0" />
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="EditPriceTextBox" Margin="0,6,0,0" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Category:" VerticalAlignment="Center" Margin="0,6,0,0" />
            <ComboBox Grid.Row="3" Grid.Column="1" x:Name="EditCategoryCombo" Margin="0,6,0,0" IsEditable="True" />

            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,8,0,0">
              <Button Content="Save" Width="80" Height="30" Click="OnSaveProductClick" />
              <Button Content="Add New" Width="90" Height="30" Margin="6,0,0,0" Click="OnAddNewProductClick" />
              <Button Content="Delete" Width="80" Height="30" Margin="6,0,0,0" Click="OnDeleteProductClick" />
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </GroupBox>

    <GroupBox Grid.Row="0" Grid.Column="1" Header="Cart">
      <DataGrid x:Name="CartLinesGrid"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                IsReadOnly="True"
                SelectionMode="Single"
                SelectionUnit="FullRow">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Item" Binding="{Binding Name}" Width="*" />
          <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="70" />
          <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotalDisplay}" Width="140" />
        </DataGrid.Columns>
      </DataGrid>
    </GroupBox>

    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,12,0,0">
      <Button Content="Remove Selected" Width="150" Height="32" Click="OnRemoveSelectedClick" />
      <Button Content="Clear" Width="90" Height="32" Margin="8,0,0,0" Click="OnClearClick" />

      <Separator Margin="16,0,16,0" Width="1" />

      <TextBlock Text="Given:" VerticalAlignment="Center" Margin="0,0,8,0" />
      <Button Content="+5 CHF" Tag="500" Width="90" Height="32" Click="OnAddGivenClick" />
      <Button Content="+10 CHF" Tag="1000" Width="90" Height="32" Margin="6,0,0,0" Click="OnAddGivenClick" />
      <Button Content="+20 CHF" Tag="2000" Width="90" Height="32" Margin="6,0,0,0" Click="OnAddGivenClick" />
      <Button Content="Given reset" Width="110" Height="32" Margin="6,0,0,0" Click="OnResetGivenClick" />

      <Separator Margin="16,0,16,0" Width="1" />

      <Button Content="Open Customer Display" Width="190" Height="32" Click="OnOpenCustomerDisplayClick" />
      <Button Content="Close Customer Display" Width="190" Height="32" Margin="6,0,0,0" Click="OnCloseCustomerDisplayClick" />
    </StackPanel>

    <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,12,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0">
        <TextBlock Text="Total" FontWeight="SemiBold" />
        <TextBlock x:Name="TotalValueText" FontSize="16" Text="CHF 0.00" />
      </StackPanel>
      <StackPanel Grid.Column="1">
        <TextBlock Text="Given" FontWeight="SemiBold" />
        <TextBlock x:Name="GivenValueText" FontSize="16" Text="CHF 0.00" />
      </StackPanel>
      <StackPanel Grid.Column="2">
        <TextBlock Text="Change" FontWeight="SemiBold" />
        <TextBlock x:Name="ChangeValueText" FontSize="16" Text="CHF 0.00" />
      </StackPanel>
    </Grid>

    <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" x:Name="StatusText" Margin="0,10,0,0" Foreground="Firebrick" />
  </Grid>
</Window>
